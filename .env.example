# Railway PostgreSQL Connection
# Copy from Railway PostgreSQL Variables tab after creating database
DATABASE_URL=postgresql://user:password@localhost:5432/spy_trader

# Flask Settings
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_APP=dashboard_server.py

# Railway Environment
RAILWAY_ENVIRONMENT=production
RAILWAY_STATIC_URL=/static

# Bot Settings
BOT_ENABLED=true
UPDATE_INTERVAL=60
LOG_LEVEL=INFO

# Target Application (Chrome or TradingView)
TARGET_APP=Chrome

# Chromium/Chrome DevTools Protocol
CHROME_CDP_URL=http://127.0.0.1:9222
