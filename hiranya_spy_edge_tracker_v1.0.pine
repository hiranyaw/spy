//@version=6
indicator("Hiranya SPY Edge Tracker v1.0", overlay=true)

// ═══════════════════════════════════════════════════════════════════════
// HIRANYA SPY EDGE TRACKER v1.0 - MINIMAL VERSION
// Only corner table display - no chart overlays
// ═══════════════════════════════════════════════════════════════════════

// ─── SIMPLE INPUTS ─────────────────────────────────────────────────────
atr_len = input.int(14, "ATR length")
ema_fast = input.int(9, "Fast EMA")
ema_slow = input.int(21, "Slow EMA")

// ─── TABLE DISPLAY CONTROLS ───────────────────────────────────────────
group_display = "TABLE DISPLAY"
cell_width = input.int(55, "Cell width", group=group_display, minval=15, maxval=200)
cell_height = input.int(20, "Cell height", group=group_display, minval=8, maxval=100)
text_sz = input.string("tiny", "Text size", options=["tiny", "small", "normal"], group=group_display)
border_sz = input.int(1, "Border width", group=group_display, minval=1, maxval=3)

// ─── CALCULATIONS ─────────────────────────────────────────────────────
atr = ta.atr(atr_len)
ema9 = ta.ema(close, ema_fast)
ema21 = ta.ema(close, ema_slow)

// ─── STATE ────────────────────────────────────────────────────────────
var int signal_count = 0
var string last_direction = "WAIT"

// Random entry for demo
if close > ema21 and close > ema9
    last_direction := "LONG"
    signal_count += 1
else if close < ema21 and close < ema9
    last_direction := "SHORT"
    signal_count += 1

// ─── CORNER TABLE ONLY ─────────────────────────────────────────────────
var table info_table = na

if na(info_table)
    info_table := table.new(position.top_right, 2, 4,
        bgcolor=color.new(color.black, 30),
        border_color=color.gray,
        border_width=border_sz)

// Map text size string to actual size
text_size_val = text_sz == "small" ? size.small : (text_sz == "normal" ? size.normal : size.tiny)

// Row 0: Direction
dir_bg = last_direction == "LONG" ? color.new(color.green, 60) :
         last_direction == "SHORT" ? color.new(color.red, 60) :
         color.new(color.gray, 60)
dir_text = last_direction == "LONG" ? color.lime :
           last_direction == "SHORT" ? color.red : color.white

table.cell(info_table, 0, 0, "Dir", text_size=text_size_val, text_color=color.white, bgcolor=color.new(color.teal, 50), width=cell_width, height=cell_height)
table.cell(info_table, 1, 0, last_direction, text_size=text_size_val, text_color=dir_text, bgcolor=dir_bg, width=cell_width, height=cell_height)

// Row 1: ATR
table.cell(info_table, 0, 1, "ATR", text_size=text_size_val, text_color=color.white, bgcolor=color.new(color.maroon, 50), width=cell_width, height=cell_height)
table.cell(info_table, 1, 1, str.tostring(math.round(atr * 100) / 100), text_size=text_size_val, text_color=color.aqua, bgcolor=color.new(color.maroon, 70), width=cell_width, height=cell_height)

// Row 2: Signals
table.cell(info_table, 0, 2, "Count", text_size=text_size_val, text_color=color.white, bgcolor=color.new(color.orange, 50), width=cell_width, height=cell_height)
table.cell(info_table, 1, 2, str.tostring(signal_count), text_size=text_size_val, text_color=color.yellow, bgcolor=color.new(color.orange, 70), width=cell_width, height=cell_height)

// Row 3: Status
status = close > ema9 ? "UP" : "DOWN"
status_color = close > ema9 ? color.new(color.green, 70) : color.new(color.red, 70)
table.cell(info_table, 0, 3, "EMA9", text_size=text_size_val, text_color=color.white, bgcolor=color.new(color.navy, 50), width=cell_width, height=cell_height)
table.cell(info_table, 1, 3, status, text_size=text_size_val, text_color=color.white, bgcolor=status_color, width=cell_width, height=cell_height)
